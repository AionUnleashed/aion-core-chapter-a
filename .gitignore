# ==========================================
# AION Core 4.7.5 - Git Ignore Configuration
# ==========================================

# ==========================================
# Compiled Class Files
# ==========================================
*.class

# ==========================================
# Build Directories (Ant & Maven)
# ==========================================
# Ant build output
build/
dist/

# Maven build output
target/

# Cache directories
cache/

# ==========================================
# Compiled JARs (Output Only)
# ==========================================
# Allow library JARs in libs/ but ignore compiled outputs
AC-Login/build/AC-Login.jar
AC-Game/build/AC-Game.jar
AC-Chat/build/AC-Chat.jar
AC-Commons/target/ac-commons-*.jar

# Ignore ac-commons JAR copies in other modules
AC-Login/libs/ac-commons-*.jar
AC-Game/libs/ac-commons-*.jar
AC-Chat/libs/ac-commons-*.jar

# Build archives
*.zip

# ==========================================
# Package Files (WAR, EAR)
# ==========================================
*.war
*.ear

# ==========================================
# Log Files
# ==========================================
log/
logs/
*.log
build.log
maven-build.log
maven-compile.log

# ==========================================
# Build Tool Temporary Files
# ==========================================
# yGuard obfuscation files
jar-yguard.xml
yshrinklog.xml

# Ant build revision
build_rev.txt

# SVN version files
svnversion

# ==========================================
# IDE Files
# ==========================================
# Eclipse
.project
.classpath
.settings/

# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr

# NetBeans
nbactions.xml
nb-configuration.xml

# VS Code
.vscode/
*.code-workspace

# ==========================================
# Mobile Tools for Java (J2ME)
# ==========================================
.mtj.tmp/

# ==========================================
# JVM Crash Logs
# ==========================================
hs_err_pid*
replay_pid*

# ==========================================
# Operating System Files
# ==========================================
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux
*~

# ==========================================
# Temporary Files
# ==========================================
*.tmp
*.temp
*.swp
*.swo
*~

# ==========================================
# Database Files (if any)
# ==========================================
*.db
*.sqlite
*.sql.backup

# ==========================================
# Documentation Build Output (keep source)
# ==========================================
# Keep markdown documentation but ignore generated HTML/PDF
*.pdf
docs/generated/

# ==========================================
# Backup Files
# ==========================================
*.bak
*.backup
*.old

# ==========================================
# Maven Wrapper (if exists)
# ==========================================
.mvn/wrapper/maven-wrapper.jar

# ==========================================
# Library Dependencies Management
# ==========================================
# AC-Commons uses Maven - ignore its libs/ (Maven downloads dependencies automatically)
AC-Commons/libs/

# Ant modules (Game/Login/Chat) need manual libraries - these MUST be committed
# (The !pattern negates previous ignores, allowing these paths)
!AC-Game/libs/**
!AC-Login/libs/**
!AC-Chat/libs/**
!AC-Tools/Ant/lib/**

# But exclude specific files inside allowed libs/ directories:
# (These rules must come AFTER the ! negations to work properly)

# Exclude ac-commons/al-commons copies (build outputs)
AC-Game/libs/**/ac-commons-*.jar
AC-Game/libs/**/al-commons-*.jar
AC-Login/libs/**/ac-commons-*.jar
AC-Login/libs/**/al-commons-*.jar
AC-Chat/libs/**/ac-commons-*.jar
AC-Chat/libs/**/al-commons-*.jar

# Exclude source JARs (not needed for runtime)
AC-Game/libs/**/*-sources.jar
AC-Login/libs/**/*-sources.jar
AC-Chat/libs/**/*-sources.jar


# Arquivos de teste temporários
test_chat_output.txt
